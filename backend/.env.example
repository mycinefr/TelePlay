# =========================================
# TelePlay - Backend Configuration
# =========================================

# -----------------------------------------
# TELEGRAM CONFIGURATION (Required)
# -----------------------------------------

# Get API ID and Hash from https://my.telegram.org
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash

# Create a bot via @BotFather and get the token
TELEGRAM_BOT_TOKEN=your_bot_token

# (Optional) Helper bots for faster download speeds (comma-separated tokens)
# IMPORTANT: All helper bots MUST be added as Administrators to your Storage Channel!
TELEGRAM_HELPER_BOT_TOKENS=token1,token2,token3

# Create a private channel, add your bot as admin, and get the channel ID
# Channel IDs start with -100 (e.g., -1001234567890)
TELEGRAM_STORAGE_CHANNEL_ID=-100xxxxxxxxxx

# (Optional) Comma separated Telegram IDs of authorized users.
# Leave empty to allow everyone to use the bot.
AUTH_USERS=

# -----------------------------------------
# SECURITY (Required)
# -----------------------------------------

# Secret key for JWT tokens - use a long random string (min 32 characters)
# Generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-key-change-in-production

# Token expiry in minutes (default: 10080 = 7 days)
JWT_EXPIRY_MINUTES=10080

# -----------------------------------------
# DATABASE
# -----------------------------------------

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/teleplay

# SQLite (no PostgreSQL setup needed — great for small/local deployments)
DATABASE_URL=sqlite:///./data/teleplay.db


# -----------------------------------------
# SERVER
# -----------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# -----------------------------------------
# WEB INTERFACE
# -----------------------------------------

# Public URL where the web app is accessible
# Used for generating links in bot messages
WEB_BASE_URL=http://localhost:3000
